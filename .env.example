# Walid Khaled Website - Environment Variables
# ==============================================
# Copy this file to .env.local (development) or set these
# variables in your hosting platform (production).
#
# Never commit real secrets to version control.

# ──────────────────────────────────────────────
# JWT Secret (REQUIRED)
# Generates session tokens for admin authentication.
# Generate: openssl rand -base64 64
# ──────────────────────────────────────────────
JWT_SECRET=

# ──────────────────────────────────────────────
# Environment
# Set to "production" for production builds.
# ──────────────────────────────────────────────
NODE_ENV=production

# ──────────────────────────────────────────────
# Admin Credentials (OPTIONAL — skip for first-run setup)
# 
# If you set these, the first-run setup page at /admin/setup
# will be skipped. The setup page guides you through creating
# an admin account interactively.
#
# Generate password hash:
#   node -e "const bcrypt=require('bcryptjs');bcrypt.hash('your-password',12).then(h=>console.log(h))"
# ──────────────────────────────────────────────
# ADMIN_USERNAME=
# ADMIN_PASSWORD_HASH=
